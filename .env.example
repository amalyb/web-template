REACT_APP_SHARETRIBE_MARKETPLACE_ID=your_marketplace_id_here
REACT_APP_SHARETRIBE_SDK_CLIENT_ID=your_sdk_client_id_here
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
SHARETRIBE_SDK_CLIENT_SECRET=your_sdk_client_secret_here
REACT_APP_MARKETPLACE_ROOT_URL=http://localhost:3000
REACT_APP_MARKETPLACE_NAME=your_marketplace_name_here
SHIPPO_API_TOKEN=your_shippo_api_token_here
REACT_APP_ENV=production
REACT_APP_CSP=report
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
ROOT_URL=
CORS_ORIGIN=
SMS_DRY_RUN=true
ONLY_PHONE=
REDIS_URL=

# ---- Late-fee charging (9.0) ----
# Master kill switch for automatic daily late-fee charging in applyCharges().
# Default 'false' — flip to 'true' in Render env to enable real charging.
OVERDUE_FEES_CHARGING_ENABLED=false
# Staging override for the daily late-fee amount in cents (default 1500 = $15).
# Set to 50 ($0.50) for safe staging dry-runs.
LATE_FEE_CENTS_OVERRIDE=

# ---- Lender share of daily late fee (May 2026) ----
# Master kill switch for routing a share of each daily late fee to the lender.
# Default 'false' — Sherbrt continues to keep 100% of late fees. Flip to 'true'
# in Render after staging verification to enable the split (lender gets
# LENDER_LATE_FEE_SHARE_PCT_OVERRIDE % of each charge at next payout).
LATE_FEE_LENDER_SHARE_ENABLED=false
# Percentage of each daily late fee allocated to the lender (0-100, default 50).
# Override for staging only (e.g. 25 for a 25/75 split dry-run). The default
# 50/50 split is set in code; this var only overrides for testing.
LENDER_LATE_FEE_SHARE_PCT_OVERRIDE=
